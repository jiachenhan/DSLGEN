functionDeclaration functiondeclaration_1 where and(
functiondeclaration_1.name match "(?i)test.*",
not(functiondeclaration_1 contain annotation annotation_1 where annotation_1.name match "(?i)(Test|RepeatedTest|TestFactory|TestTemplate|ParameterizedTest)"),
not(functiondeclaration_1 contain annotation annotation_2 where and(
annotation_2.name == "Timeout",
annotation_2.annoMembers contain literal literal_1 where literal_1.value == 2000
))
);