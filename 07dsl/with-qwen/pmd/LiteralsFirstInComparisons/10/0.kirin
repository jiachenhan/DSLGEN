functionDeclaration functiondeclaration_1 where and(
functiondeclaration_1.body contain functionCall functioncall_1 where functioncall_1.name == "equals",
functiondeclaration_1.body contain ifBlock ifblock_1 where and(
ifblock_1.condition.arguments contain alias_1 where and(
alias_1 is literal,
alias_1.value match "(?i)(android|system)"
),
ifblock_1.condition.name == "equals"
)
);