functionDeclaration functiondeclaration_1 where and(
functiondeclaration_1.body contain functionCall functioncall_1 where and(
functioncall_1.arguments contain alias_1 where and(
alias_1 is literal,
alias_1.value == true
),
functioncall_1.name match "(?i).*setAccessible"
),
not(functiondeclaration_1.body contain functionCall functioncall_2 where functioncall_2.base.name match "(?i).*(util|helper|tool|reflect)$")
);