functionDeclaration functiondeclaration_1 where functiondeclaration_1.body contain valueDeclaration valuedeclaration_1 where and(
valuedeclaration_1.initializer.arguments contain alias_1 where and(
alias_1 is functionCall,
alias_1.base.name == "List"
),
valuedeclaration_1.initializer.type.name match ".*(?i).*(ArrayList|LinkedList|Vector|CopyOnWriteArrayList)$",
valuedeclaration_1.type.name match ".*(?i)(ArrayList|LinkedList|Vector|CopyOnWriteArrayList)"
);