functionDeclaration functiondeclaration_1 where and(
functiondeclaration_1.body contain functionCall functioncall_1 where and(
functioncall_1.arguments contain alias_1 where alias_1.name match "(?i).*rs.*",
functioncall_1.base.name match "(?i).*(Utils|Helper)$",
functioncall_1.arguments contain alias_2 where alias_2.name match "(?i).*conn.*"
),
functiondeclaration_1.body contain valueDeclaration valuedeclaration_1 where valuedeclaration_1.type.name match ".*Connection"
);