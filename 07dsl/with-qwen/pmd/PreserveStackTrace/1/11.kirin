functionDeclaration functiondeclaration_1 where functiondeclaration_1.body contain catchBlock catchblock_1 where and(
catchblock_1.body contain throwStatement throwstatement_1 where throwstatement_1.operand.arguments contain alias_1 where and(
alias_1 is functionCall,
alias_1.name match "(getException|getCause|getRootCause)"
),
not(catchblock_1.body contain valueDeclaration valuedeclaration_1 where valuedeclaration_1.type.name match ".*Throwable"),
not(catchblock_1.body contain ifBlock ifblock_1 where ifblock_1.condition.lhs.name match "(?i)ex$")
);