functionDeclaration functiondeclaration_1 where and(
functiondeclaration_1.body contain objectCreationExpression objectcreationexpression_1 where and(
objectcreationexpression_1.arguments contain alias_1 where alias_1.name == "rowSize",
not(objectcreationexpression_1 contain functionCall functioncall_2 where functioncall_2.base.name match "(?i).*tablet.*")
),
functiondeclaration_1.body contain binaryOperation binaryoperation_1 where and(
binaryoperation_1.rhs.name match "(?i).*\.rowSize",
not(binaryoperation_1 contain functionCall functioncall_1 where functioncall_1.base.name match "(?i)tablet")
)
);