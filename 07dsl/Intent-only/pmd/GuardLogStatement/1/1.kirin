functionCall fc where
    and(
        fc.base.name match "LOG",
        fc.name == "debug",
        not(
            fc.parent is ifStatement where
                fc.parent.condition is functionCall where
                    and(
                        fc.parent.condition.base.name match "LOG",
                        fc.parent.condition.name == "isDebugEnabled"
                    )
        )
    );