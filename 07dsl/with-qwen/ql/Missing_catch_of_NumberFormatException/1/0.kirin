functionDeclaration functiondeclaration_1 where and(
functiondeclaration_1.body contain methodReferenceExpression methodreferenceexpression_1 where methodreferenceexpression_1.name match "(parseInt|valueOf|parseLong|parseShort|parseByte|parseDouble|parseFloat)",
