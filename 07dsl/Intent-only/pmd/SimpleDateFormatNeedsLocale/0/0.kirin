objectCreationExpression oce where
    and(
        oce.name == "SimpleDateFormat",
        oce.arguments.size() == 1,
        not(
            oce.arguments[0] is functionCall where
                and(
                    name == "ofPattern",
                    arguments.size() == 2,
                    arguments[1] is objectCreationExpression where
                        name == "Locale"
                )
        )
    );