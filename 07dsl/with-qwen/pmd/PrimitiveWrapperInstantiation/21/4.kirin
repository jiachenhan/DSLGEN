functionDeclaration functiondeclaration_1 where and(
functiondeclaration_1.body contain objectCreationExpression objectcreationexpression_1 where objectcreationexpression_1.type.name match ".*(?i)(Long|Integer|Byte|Short|Character|Boolean|Float|Double)",
functiondeclaration_1.body contain valueDeclaration valuedeclaration_1 where valuedeclaration_1.type.name match ".*(?i)(Long|Integer|Byte|Short|Character|Boolean|Float|Double)"
