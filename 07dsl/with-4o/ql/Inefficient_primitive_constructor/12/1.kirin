functionDeclaration functiondeclaration_1 where functiondeclaration_1.body contain returnStatement returnstatement_1 where and(
returnstatement_1.returnValue.type.name match ".*(?i)(Float|Double|Integer|Long|Byte|Short)",
not(returnstatement_1 contain functionCall functioncall_1 where functioncall_1.base.name == "Float")
);