functionDeclaration functiondeclaration_1 where functiondeclaration_1.body contain catchBlock catchblock_1 where and(
catchblock_1.body contain throwStatement throwstatement_1 where throwstatement_1.operand.arguments contain alias_1 where alias_1 is functionCall,
not(catchblock_1.body contain valueDeclaration valuedeclaration_1 where valuedeclaration_1.type.name match ".*(?i)(error|exception|throwable)"),
not(catchblock_1.body contain ifBlock ifblock_1)
);