functionCall fc where
    and(
        fc.base.name match "log.*",
        fc.name == "info",
        not(
            fc.enclosingBlock contain ifStatement ifs where
                and(
                    ifs.condition is functionCall ifc where
                        and(
                            ifc.base.name == fc.base.name,
                            ifc.name == "isInfoEnabled"
                        )
                )
        )
    );