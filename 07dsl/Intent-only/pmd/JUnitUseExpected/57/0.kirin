methodDeclaration md where
    and(
        md.name startWith "test",
        md.contain tryStatement ts where
            ts.contain catchBlock cb where
                cb.exceptionType.name == "RuntimeException",
        not(
            md.contain functionCall fc where
                and(
                    fc.name == "assertThrows",
                    fc.arguments[0].type.name == "NoResultException.class"
                )
        )
    );