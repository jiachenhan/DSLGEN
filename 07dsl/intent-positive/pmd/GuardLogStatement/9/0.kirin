functioncall_1.base.name match "(?i).*(logger|log)$",
functioncall_1.name match "(?i).*(info|debug|warn|error|trace)"
),
functiondeclaration_1.body contain functionCall functioncall_2 where and(
functioncall_2.base.name match "(?i).*(logger|log)",
