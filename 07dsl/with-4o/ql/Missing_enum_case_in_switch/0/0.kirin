functionDeclaration functiondeclaration_1 where functiondeclaration_1.body contain switchBlock switchblock_1 where and(
switchblock_1.body contain caseStatement casestatement_1,
not(switchblock_1 contain throwStatement throwstatement_1 where throwstatement_1.operand.type.name match ".*IllegalArgumentException"),
not(switchblock_1 contain defaultStatement)
);