functionDeclaration functiondeclaration_1 where and(
functiondeclaration_1.body contain binaryOperation binaryoperation_1 where and(
binaryoperation_1.rhs.operand.name match "(?i).*\.rowSize$",
binaryoperation_1.rhs.operator == "++",
not(binaryoperation_1 contain functionCall functioncall_1 where functioncall_1.base.name match "(?i)(tablet|dataContainer|recordHolder)$")
),
functiondeclaration_1.body contain unaryOperation unaryoperation_1 where unaryoperation_1.operator == "++"
);