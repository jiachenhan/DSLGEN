functionDeclaration functiondeclaration_1 where and(
functiondeclaration_1.body contain synchronizedBlock synchronizedblock_1 where and(
synchronizedblock_1.body contain binaryOperation binaryoperation_1 where binaryoperation_1.lhs.name match "(?i)(busy|lock|mutex|flag|state)",
synchronizedblock_1.body contain ifBlock ifblock_1 where ifblock_1.condition.name match "(?i).*(busy|lock|mutex|flag)$"
),
not(functiondeclaration_1.body contain functionCall functioncall_1 where and(
functioncall_1.base.name == "projectData",
functioncall_1.name == "mergeStarted"
))
);