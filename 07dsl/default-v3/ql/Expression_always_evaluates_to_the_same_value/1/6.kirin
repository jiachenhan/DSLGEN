functionDeclaration functiondeclaration_1 where functiondeclaration_1.body contain binaryOperation binaryoperation_1 where and(
binaryoperation_1.rhs.operator == "++",
binaryoperation_1.rhs.operand.name match "(?i).*(size|index|row|count)$",
not(binaryoperation_1 contain functionCall functioncall_1 where functioncall_1.base.name match "(?i).*(tablet|device|object|entity|instance)$")
);