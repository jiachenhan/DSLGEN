functionDeclaration functiondeclaration_1 where and(
functiondeclaration_1.body contain objectCreationExpression objectcreationexpression_1 where objectcreationexpression_1.type.name match ".*Integer|Float|Double|Short|Byte|Long",
functiondeclaration_1.body contain functionCall functioncall_1 where functioncall_1.arguments contain alias_1 where and(
alias_1 is objectCreationExpression,
alias_1.type.name match ".*Integer"
)
);