functionDeclaration functiondeclaration_1 where functiondeclaration_1.body contain functionCall functioncall_1 where and(
functioncall_1.arguments contain alias_1 where and(
alias_1 is literal,
alias_1.value match "(?i).*(utf-8|iso-8859-1|us-ascii)"
),
functioncall_1.base.name == "Charset",
functioncall_1.name == "forName"
);