functionDeclaration functiondeclaration_1 where and(
functiondeclaration_1.body contain catchBlock catchblock_1 where catchblock_1.parameters contain alias_1 where and(
alias_1 is valueDeclaration,
alias_1.type.name match ".*NullPointerException"
),
not(functiondeclaration_1.body contain functionCall functioncall_1 where and(
functioncall_1.name == "assertThrows",
functioncall_1.base.name == "Assertions"
))
);