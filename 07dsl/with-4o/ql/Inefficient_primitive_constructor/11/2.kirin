functionDeclaration functiondeclaration_1 where functiondeclaration_1.body contain returnStatement returnstatement_1 where and(
returnstatement_1.returnValue.type.name match ".*Integer",
returnstatement_1.returnValue.arguments contain alias_1 where alias_1 is castExpression,
not(returnstatement_1 contain functionCall functioncall_1 where functioncall_1.base.name == "Integer")
);