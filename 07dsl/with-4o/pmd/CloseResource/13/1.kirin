functionDeclaration functiondeclaration_1 where and(
functiondeclaration_1.body contain functionCall functioncall_1 where functioncall_1.base.name match "(?i).*(Utils)$",
functiondeclaration_1.body contain binaryOperation binaryoperation_1 where binaryoperation_1.lhs.name match "(?i)conn.*",
functiondeclaration_1.body contain valueDeclaration valuedeclaration_1 where valuedeclaration_1.type.name match ".*ResultSet",
functiondeclaration_1.body contain valueDeclaration valuedeclaration_2 where and(
valuedeclaration_2.type.name match ".*PreparedStatement",
valuedeclaration_2.name match "(?i)p(stmt|reparedStatement)"
),
functiondeclaration_1.body contain valueDeclaration valuedeclaration_3 where valuedeclaration_3.type.name match ".*Connection"
);