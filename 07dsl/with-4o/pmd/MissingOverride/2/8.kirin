functionDeclaration functiondeclaration_1 where and(
functiondeclaration_1.body contain objectCreationExpression objectcreationexpression_1 where objectcreationexpression_1.type.name match ".*Comparator",
functiondeclaration_1.body contain functionDeclaration functiondeclaration_2 where and(
functiondeclaration_2.name == "compare",
not(functiondeclaration_2 contain annotation annotation_1 where annotation_1.name == "Override")
)
);